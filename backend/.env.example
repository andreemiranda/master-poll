# ─────────────────────────────────────────────────────────────
# .env.example — Copie como .env para desenvolvimento local
# Em produção (Render.com) configure via painel de Env Vars
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001

# URL do frontend (separar múltiplas com vírgula)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Diretório de dados persistente
# Render produção: /var/data  (requer disco)
# Desenvolvimento: ./data     (padrão se não definido)
DATA_DIR=./data

# Segredo JWT — use um valor longo e aleatório em produção
# Gerar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE-ESTE-VALOR-EM-PRODUCAO

# Senhas iniciais — se não definidas usa admin123/super123
# TROQUE IMEDIATAMENTE em produção!
ADMIN_PASSWORD=admin123
SUPERUSER_PASSWORD=super123
